.idea
.aider*
.env*
klique
kasmos
**.DS_Store
kq
kas
.worktrees/
/.kasmos/*
!/.kasmos/config.toml
# Ignore nested .kasmos runtime state in any subdirectory
**/.kasmos/state.json
**/.kasmos/taskstore.db
**/.kasmos/taskstore.db-shm
**/.kasmos/taskstore.db-wal
**/.kasmos/config.json
**/.kasmos/config.toml
dist/
*.bak
# Plan markdown files — content lives in the task store DB, not on disk
docs/plans/
*.test
.mcp.json
# Bundled skill data (large, fetched locally)
.agents/skills/bubbletea/

# Scaffold-generated skill symlinks (created by kq init, point to .agents/skills/)
# Actual skill directories in .claude/skills/ (with SKILL.md) remain tracked.
.opencode/skills/*
!.opencode/skills/*/
.codex/skills/*
# .claude/skills/ has both real dirs and symlinks — ignore files (symlinks), keep dirs
.claude/skills/*
!.claude/skills/*/
